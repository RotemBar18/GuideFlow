<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The SDK fetches remote config and uploads analytics over HTTP. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application>
        <!-- Optional auto-init: runs GuideFlowInitializer at app startup. It only
             initializes if the app declares a com.guideflow.PROJECT_KEY meta-data,
             so manual GuideFlow.initialize(...) still works unchanged. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="com.guideflow.sdk.api.GuideFlowInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>
